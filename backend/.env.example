# SSS Backend — Environment Variables
#
# Copy this file to `.env` and fill in values for your deployment.
# Variables marked REQUIRED must be set for full functionality.
# Variables marked OPTIONAL have sensible defaults.

# ── Server ────────────────────────────────────────────────────────────────

# Port for the HTTP server (OPTIONAL, default: 3001)
PORT=3001

# API key for authentication (OPTIONAL, disabled if empty)
# Set this to require `X-API-Key` header on all API requests (except /health).
# SSS_API_KEY=your-secret-api-key

# ── Solana RPC ────────────────────────────────────────────────────────────

# Solana RPC URL (OPTIONAL, default: http://127.0.0.1:8899)
RPC_URL=http://127.0.0.1:8899

# SSS program ID (OPTIONAL, default: DNfk1e2vMJrxHm4BwoRTVqQxcfYjZLHggxr11hMZ5Dyu)
# SSS_PROGRAM_ID=DNfk1e2vMJrxHm4BwoRTVqQxcfYjZLHggxr11hMZ5Dyu

# ── Stablecoin Configuration ──────────────────────────────────────────────

# Token-2022 mint address for the stablecoin (REQUIRED for Solana operations)
# If not set, the backend starts in degraded mode (health check works, but
# mint/burn/compliance/indexer endpoints return 503).
SSS_MINT_ADDRESS=

# Path to the service keypair JSON file (OPTIONAL, default: ~/.config/solana/id.json)
# This keypair must hold the required on-chain roles (Minter, Burner, Blacklister, etc.)
# SSS_KEYPAIR_PATH=/path/to/keypair.json

# ── Indexer ───────────────────────────────────────────────────────────────

# Background polling interval in seconds (OPTIONAL, default: 10)
# SSS_INDEXER_INTERVAL_SECS=10

# ── Redis ─────────────────────────────────────────────────────────────────

# Redis connection URL (OPTIONAL, default: disabled / file-based persistence)
# When set, all service state is persisted to Redis instead of local JSON files.
# REDIS_URL=redis://127.0.0.1:6379

# ── Logging ───────────────────────────────────────────────────────────────

# Rust log filter (OPTIONAL, default: sss_backend=debug,tower_http=debug)
# RUST_LOG=sss_backend=info,tower_http=info
