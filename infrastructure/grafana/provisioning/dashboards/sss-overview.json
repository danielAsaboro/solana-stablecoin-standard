      "targets": [
        {
          "expr": "sum(rate(sss_http_requests_total{path=\"/api/v1/webhooks\",status=~\"2..\"}[5m])) / sum(rate(sss_http_requests_total{path=\"/api/v1/webhooks\"}[5m]))",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ]
    },
