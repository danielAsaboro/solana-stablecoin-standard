{
  "name": "@stbr/solana-stablecoin-standard",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "sdk/core",
    "sdk/compliance",
    "sdk/token",
    "cli"
  ],
  "scripts": {
    "build:programs": "anchor build",
    "build:packages": "npm run build --workspace @stbr/sss-core-sdk && npm run build --workspace @stbr/sss-compliance-sdk && npm run build --workspace @stbr/sss-token && npm run build --workspace @stbr/sss-cli",
    "build": "npm run build:programs && npm run build:packages",
    "surfpool:start": "surfpool start --network mainnet --legacy-anchor-compatibility --yes --no-tui --no-studio",
    "test:anchor": "npx ts-mocha -p ./tsconfig.json -t 1000000 tests/**/*.ts",
    "test:sdk": "npm run test --workspace @stbr/sss-core-sdk && npm run test --workspace @stbr/sss-compliance-sdk && npm run test --workspace @stbr/sss-token",
    "test:cli": "npm run test --workspace @stbr/sss-cli",
    "test:backend": "cargo test --manifest-path backend/Cargo.toml",
    "test:fuzz": "cargo test --manifest-path trident-tests/Cargo.toml",
    "test:frontend": "npm --prefix frontend run build",
    "test:tui": "cargo test --manifest-path tui/Cargo.toml",
    "test:local": "./scripts/test-local.sh",
    "test": "npm run test:local",
    "codama:generate": "npx ts-node codama.config.ts"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.10",
    "@solana/web3.js": "^1.98.0"
  },
  "devDependencies": {
    "@codama/nodes-from-anchor": "^1.3.9",
    "@codama/renderers-js": "^2.0.3",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "chai": "^4.4.1",
    "codama": "^1.5.1",
    "mocha": "^10.3.0",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.3.3"
  }
}
